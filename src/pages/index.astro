---
import BaseLayout from "../layouts/BaseLayout.astro";

const name = "Sahil Arora";
const email = "sahila99@gmail.com";
const linkedin = "https://www.linkedin.com/in/sahil-arora-38263b158";

/* UI helpers */
const card =
  "rounded-3xl border border-white/10 bg-white/5 backdrop-blur-sm hover:bg-white/10 hover:-translate-y-0.5 transition";
const softCard =
  "rounded-2xl border border-white/10 bg-white/5 backdrop-blur-sm hover:bg-white/10 hover:-translate-y-0.5 transition";
const divider = "my-16 h-px w-full bg-white/10";

/* Positioning (Senior + Consultant) */
const whatYouCanExpect = [
  "Enterprise Transformation And Technology Strategy",
  "Cloud Enterprise Architecture",
  "AI Transformation Leadership",
  "AI Strategy And Operating Model",
  "AI Workflow Architecture And Orchestration",
  "Automation And Process Standardization",
  "IT/OT Alignment For Operational Excellence",
  "Cybersecurity Governance And Risk Reduction",
  "Enterprise Platforms And ERP Systems",
];

const industriesLine =
  "Technology Leadership Experience Across Multiple Industries Including FinTech, Manufacturing, Healthcare, FMCG, Mining, Agriculture, Aviation, Automobile, And Enterprise Sectors.";

const focusAreas = [
  { title: "Enterprise Technology Strategy", desc: "Translate Business Priorities Into A Clear Roadmap, Target Architecture, And Measurable Outcomes." },
  { title: "Cloud Enterprise Architecture", desc: "Design Scalable Cloud Platforms With Reliability, Cost Governance, Security, And Performance Built In." },
  { title: "AI Transformation Leadership", desc: "Enable AI Adoption To Improve Efficiency, Decision-Making, And Profitability Through Practical Use Cases." },
  { title: "AI Workflow Architecture", desc: "Design AI-Driven Workflows That Automate Work, Connect Systems, And Improve Operational Consistency." },
  { title: "AI Orchestration", desc: "Orchestrate AI Tools, Agents, And Automation Across Processes So Outcomes Are Repeatable And Governed." },
  { title: "IT/OT Convergence", desc: "Align IT And OT To Improve Visibility, Reliability, Downtime Reduction, And Site-Level Performance." },
  { title: "Cybersecurity Governance", desc: "Strengthen Risk Management, Monitoring, Incident Readiness, And Audit Posture Without Slowing Delivery." },
  { title: "Enterprise Platforms (ERP) And Integration", desc: "Enable Connected Operations Through ERP, Integrations, And Decision-Grade Reporting." },
];

const advisoryCards = [
  { title: "Enterprise Technology Strategy", desc: "Advising Leadership Teams On Roadmaps That Support Growth, Resilience, And Operational Performance." },
  { title: "Cloud And AI Transformation", desc: "Guiding Modernization, AI Adoption, And Automation-Driven Operating Models With Governance." },
  { title: "Operational Efficiency And Governance", desc: "Designing Systems, Controls, And Operating Frameworks That Reduce Risk While Improving Efficiency." },
];

const engagementTypes = [
  { title: "Assessment & Roadmap", desc: "Current-State Review Across IT/OT, Risk, And Operations—Ending With A Prioritized Roadmap And Business Case." },
  { title: "Transformation Program", desc: "End-To-End Delivery For Platforms, Security, AI/Automation, And Governance—With Cadence, KPIs, And Alignment." },
  { title: "Operational Excellence", desc: "Stabilize Services, Improve Reliability, Reduce Cost, And Build A Repeatable Operating Model With ITSM And Automation." },
];

const snapshot = [
  { value: "25%", label: "Operating Cost Reduction Through Infrastructure Modernization And Standardization" },
  { value: "40%", label: "Improvement In Threat Detection Capability Through Governance And Monitoring Uplift" },
  { value: "5,000+", label: "Users Enabled Through Enterprise Workplace Transformation And Adoption Programs" },
];

const operatingModel = [
  ["Discover", "Understand Business Constraints, Operational Reality (OT), And Risk Profile Before Designing Solutions."],
  ["Design", "Define Target Architecture, Controls, And A Practical Roadmap That Teams Can Execute."],
  ["Deliver", "Run Programs With Cadence, Ownership, And Measurable KPIs Across IT And OT Stakeholders."],
  ["Sustain", "Standardize, Automate, Document, And Build Capability So Improvements Last Beyond The Project."],
];

const philosophy = [
  ["Start With The Business", "Tie Technology Decisions To Business Priorities, Operational Reality, And Financial Outcomes."],
  ["Systems Before Tools", "Build Processes, Controls, And Platforms First—Then Scale With Technology."],
  ["Automation Creates Leverage", "Reduce Manual Work To Improve Consistency, Throughput, And Profitability."],
  ["IT/OT Alignment Matters", "Unify Visibility And Accountability Across Technology And Operations For Better Performance."],
];

const transformations = [
  {
    title: "Infrastructure And Platform Modernization",
    body: "Simplified Legacy Infrastructure, Standardized Platforms, And Strengthened Governance To Reduce Complexity And Improve Reliability.",
    outcome: "Outcome: Reduced Operating Costs By Approximately 25% While Improving Stability Across Enterprise Systems.",
  },
  {
    title: "Cybersecurity Governance And Monitoring",
    body: "Improved Governance, Monitoring, And Response Readiness To Strengthen Security Posture And Risk Control.",
    outcome: "Outcome: Improved Detection Capability By Approximately 40% And Enhanced Organizational Readiness.",
  },
  {
    title: "Enterprise Digital Workplace Transformation",
    body: "Enabled Collaboration Platforms And Adoption Programs To Improve Productivity And Cross-Functional Execution.",
    outcome: "Outcome: Enabled Over 5,000 Users With Modern Collaboration Tools And Improved Operational Efficiency.",
  },
];

const journey = [
  { role: "Technology Leader / IT Head", focus: "Enterprise Strategy • Governance • Transformation Leadership • IT/OT Alignment" },
  { role: "IT Lead", focus: "Program Execution • Platform Modernization • Stakeholder Alignment" },
  { role: "Senior IT Manager", focus: "Operations Excellence • Team Leadership • Vendor Governance" },
  { role: "IT Manager", focus: "Infrastructure Operations • Service Delivery • Reliability" },
  { role: "Network Engineer", focus: "Enterprise Networking • Core Infrastructure Foundations" },
];

const principles = [
  { t: "Business Outcomes Drive Technology Decisions", d: "I Start With Business Goals And Build The Systems, Controls, And Roadmap Needed To Deliver Measurable Value." },
  { t: "Governance Should Enable Speed", d: "Decision Rights, Standards, And Controls Reduce Risk While Keeping Teams Fast And Execution Predictable." },
  { t: "Automation Improves Efficiency And Profitability", d: "I Reduce Manual Dependency Through Automation, Standardization, And Platforms That Scale Across Operations." },
  { t: "IT/OT Alignment Builds Real Operational Advantage", d: "When IT And OT Work Together, Reliability Improves, Downtime Reduces, And Performance Becomes Visible And Actionable." },
];
---

<BaseLayout title="Sahil Arora | Technology Leader • Cloud Enterprise Architect • AI Transformation Leader">
  <!-- Floating Resume Button (Desktop Only) -->
  <a
    href="/resume.pdf"
    target="_blank"
    class="hidden md:flex fixed right-6 bottom-6 z-30 items-center gap-2 rounded-2xl border border-white/15 bg-white/10 px-4 py-3 text-sm text-white backdrop-blur-sm hover:bg-white/20 transition"
  >
    Resume
  </a>

  <!-- HEADER -->
  <header class="sticky top-0 z-20 border-b border-white/10 bg-zinc-950/40 backdrop-blur shadow-[0_10px_30px_rgba(0,0,0,0.25)]">
    <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4 md:px-8">
      <div class="font-semibold tracking-tight">{name}</div>

      <nav class="hidden gap-6 text-sm text-zinc-300 md:flex">
        <a href="#focus" class="hover:text-white transition">Focus</a>
        <a href="#advisory" class="hover:text-white transition">Advisory</a>
        <a href="#engagements" class="hover:text-white transition">Engagements</a>
        <a href="#value" class="hover:text-white transition">Value</a>
        <a href="#model" class="hover:text-white transition">Operating Model</a>
        <a href="#philosophy" class="hover:text-white transition">Philosophy</a>
        <a href="#transformations" class="hover:text-white transition">Transformations</a>
        <a href="#journey" class="hover:text-white transition">Journey</a>
        <a href="#principles" class="hover:text-white transition">Principles</a>
        <a href="#contact" class="hover:text-white transition">Contact</a>
        <a href="/resume.pdf" target="_blank" class="hover:text-white transition">Resume</a>
      </nav>
    </div>
  </header>

  <main class="mx-auto max-w-6xl px-6 md:px-8">
    <!-- HERO -->
    <section class="py-20 md:py-24">
      <div class="grid gap-10 md:grid-cols-2 md:items-start">
        <div>
          <p class="fade-up inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-4 py-1.5 text-xs text-zinc-300 backdrop-blur-sm shadow-sm">
            Enterprise Transformation • Cloud Architecture • AI Strategy • Automation • Governance • IT/OT Systems
          </p>

          <h1 class="fade-up fade-delay-1 mt-6 text-4xl md:text-5xl font-semibold leading-[1.1] tracking-tight max-w-2xl">
            Technology Leadership Driving Enterprise Transformation Across IT And Operations.
          </h1>

          <p class="fade-up fade-delay-2 mt-4 text-lg text-zinc-300 max-w-2xl leading-relaxed">
            Improving Efficiency, Strengthening Governance, And Enabling Profitable Growth Through Cloud Architecture, AI Transformation, Automation, And IT/OT Alignment.
          </p>

          <p class="fade-up fade-delay-2 mt-5 max-w-xl text-sm leading-relaxed text-zinc-400">
            I Help Organizations Build The Right Systems And Operating Model—So Transformation Is Scalable, Secure, And Reliable.
            My Work Focuses On Measurable Business Outcomes: Reduced Cost, Higher Productivity, Lower Risk, And Better Operational Performance.
          </p>

          <div class="fade-up fade-delay-3 mt-8 flex flex-wrap gap-3">
            <a href={`mailto:${email}`} class="rounded-xl bg-white px-5 py-3 text-sm font-medium text-zinc-900 hover:bg-zinc-200 transition">
              Email
            </a>

            <a href={linkedin} target="_blank" class="rounded-xl border border-white/20 bg-white/5 px-5 py-3 text-sm text-white hover:bg-white/10 transition">
              LinkedIn
            </a>

            <a href="/resume.pdf" target="_blank" class="rounded-xl border border-white/20 bg-white/5 px-5 py-3 text-sm text-white hover:bg-white/10 transition">
              Resume
            </a>
          </div>

          <div class={"mt-10 p-5 " + card}>
            <div class="text-xs uppercase tracking-[0.2em] text-zinc-500">What You Can Expect</div>
            <div class="mt-4 flex flex-wrap gap-2 text-xs">
              {whatYouCanExpect.map((o) => (
                <span class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-zinc-200">
                  {o}
                </span>
              ))}
            </div>
          </div>
        </div>

        <!-- PROFILE -->
        <div>
          <div class={"p-6 " + card + " shadow-[0_10px_40px_rgba(0,0,0,0.35)]"}>
            <div class="flex items-center gap-5">
              <img
                src="/images/sahil.jpg"
                alt="Sahil Arora"
                class="h-24 w-24 rounded-3xl object-cover border border-white/10 shadow-lg"
                loading="lazy"
                onerror="this.style.display='none'"
              />

              <div class="min-w-0">
                <div class="text-xl font-semibold tracking-tight">{name}</div>
                <div class="mt-1 text-sm text-zinc-400">
                  Technology Leader • Cloud Enterprise Architect • AI Transformation Leader • IT/OT Alignment
                </div>
              </div>
            </div>

            <div class="mt-5 space-y-2 text-sm text-zinc-400">
              <div>
                <span class="text-zinc-300">Email:</span>{" "}
                <a class="underline underline-offset-4 hover:text-white" href={`mailto:${email}`}>
                  {email}
                </a>
              </div>
              <div>
                <span class="text-zinc-300">LinkedIn:</span>{" "}
                <a class="underline underline-offset-4 hover:text-white" href={linkedin} target="_blank">
                  sahil-arora-38263b158
                </a>
              </div>
            </div>

            <div class="mt-6 border-t border-white/10 pt-5 text-sm text-zinc-300">
              {industriesLine}
            </div>
          </div>
        </div>
      </div>
    </section>

    <div class={divider}></div>

    <!-- FOCUS -->
    <section id="focus" class="pb-20 scroll-mt-28">
      <div class="text-xs uppercase tracking-[0.2em] text-zinc-500">Strategic Focus Areas</div>
      <h2 class="mt-4 text-2xl font-semibold tracking-tight">Where I Drive Transformation</h2>
      <p class="mt-3 max-w-3xl text-sm leading-relaxed text-zinc-300">
        A Senior Leadership And Consulting View: Business Value First, Systems And Controls In Place, Automation Where It Matters, And Strong Governance Across IT And OT.
      </p>

      <div class="mt-8 grid gap-4 md:grid-cols-2">
        {focusAreas.map((f) => (
          <div class={"p-6 " + card}>
            <div class="text-sm font-semibold">{f.title}</div>
            <p class="mt-2 text-sm leading-relaxed text-zinc-400">{f.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- ADVISORY -->
    <section id="advisory" class="pb-20 scroll-mt-28">
      <div class="text-xs uppercase tracking-[0.2em] text-zinc-500">Advisory</div>
      <h2 class="mt-4 text-2xl font-semibold tracking-tight">Technology And Transformation Advisory</h2>

      <p class="mt-3 max-w-3xl text-sm leading-relaxed text-zinc-300">
        I Advise Organizations On Building Scalable Systems, Modernizing Infrastructure, Strengthening Governance, And Applying AI To Improve Operational Efficiency And Business Performance Across Enterprise And IT/OT Environments.
      </p>

      <div class="mt-8 grid gap-4 md:grid-cols-3">
        {advisoryCards.map((a) => (
          <div class={"p-6 " + card}>
            <div class="text-sm font-semibold">{a.title}</div>
            <p class="mt-2 text-sm leading-relaxed text-zinc-400">{a.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- ENGAGEMENTS -->
    <section id="engagements" class="pb-20 scroll-mt-28">
      <div class="text-xs uppercase tracking-[0.2em] text-zinc-500">Engagement Types</div>
      <h2 class="mt-4 text-2xl font-semibold tracking-tight">How I Work With Organizations</h2>

      <div class="mt-8 grid gap-4 md:grid-cols-3">
        {engagementTypes.map((e) => (
          <div class={"p-6 " + card}>
            <div class="text-sm font-semibold">{e.title}</div>
            <p class="mt-2 text-sm leading-relaxed text-zinc-400">{e.desc}</p>
          </div>
        ))}
      </div>

      <div class={"mt-10 p-6 " + card}>
        <div class="text-sm font-semibold">Typical Outcomes</div>
        <p class="mt-2 text-sm leading-relaxed text-zinc-300 max-w-4xl">
          Faster Execution • Lower Operational Cost • Improved Reliability • Stronger Security Posture • Better Visibility Across IT/OT • Standardized Systems And Processes • Reduced Manual Work Through Automation • AI-Enabled Productivity Gains.
        </p>
      </div>
    </section>

    <div class={divider}></div>

    <!-- VALUE -->
    <section id="value" class="pb-20 scroll-mt-28">
      <div class="text-xs uppercase tracking-[0.2em] text-zinc-500">Business Value</div>
      <h2 class="mt-4 text-2xl font-semibold tracking-tight">Executive Snapshot</h2>

      <div class="mt-8 grid gap-8 md:grid-cols-3">
        {snapshot.map((s) => (
          <div class={"p-6 " + card}>
            <div class="text-4xl font-semibold tracking-tight">{s.value}</div>
            <div class="mt-2 text-sm leading-relaxed text-zinc-400">{s.label}</div>
          </div>
        ))}
      </div>
    </section>

    <!-- OPERATING MODEL -->
    <section id="model" class="pb-20 scroll-mt-28">
      <div class="text-xs uppercase tracking-[0.2em] text-zinc-500">Operating Model</div>
      <h2 class="mt-4 text-2xl font-semibold tracking-tight">How I Lead Transformation Programs</h2>

      <div class="mt-10 grid gap-8 md:grid-cols-4">
        {operatingModel.map(([t, d]) => (
          <div>
            <div class="text-sm font-semibold">{t}</div>
            <p class="mt-2 text-sm leading-relaxed text-zinc-400">{d}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- PHILOSOPHY -->
    <section id="philosophy" class="pb-20 scroll-mt-28">
      <div class="text-xs uppercase tracking-[0.2em] text-zinc-500">Transformation Philosophy</div>
      <h2 class="mt-4 text-2xl font-semibold tracking-tight">How I Think About Sustainable Transformation</h2>

      <p class="mt-3 max-w-3xl text-sm leading-relaxed text-zinc-300">
        Sustainable Transformation Is Not Just About New Tools. It Requires The Right Systems, Governance, And Operating Model So Organizations Scale Efficiently, Perform Reliably, And Improve Business Outcomes Across IT And OT.
      </p>

      <div class="mt-8 grid gap-4 md:grid-cols-2">
        {philosophy.map(([t, d]) => (
          <div class={"p-6 " + card}>
            <div class="text-sm font-semibold">{t}</div>
            <p class="mt-2 text-sm leading-relaxed text-zinc-400">{d}</p>
          </div>
        ))}
      </div>
    </section>

    <div class={divider}></div>

    <!-- TRANSFORMATIONS -->
    <section id="transformations" class="pb-20 scroll-mt-28">
      <div class="text-xs uppercase tracking-[0.2em] text-zinc-500">Transformation Examples</div>
      <h2 class="mt-4 text-2xl font-semibold tracking-tight">Selected Transformation Outcomes</h2>

      <p class="mt-3 max-w-3xl text-sm leading-relaxed text-zinc-300">
        Examples Of Transformation Work Focused On Operational Efficiency, Governance, And Measurable Business Outcomes Through Cloud Modernization, AI/Automation, Systems, And IT/OT Alignment.
      </p>

      <div class="mt-8 grid gap-6 md:grid-cols-3">
        {transformations.map((x) => (
          <div class={"p-6 " + card}>
            <div class="text-sm font-semibold">{x.title}</div>
            <p class="mt-3 text-sm text-zinc-400">{x.body}</p>
            <p class="mt-3 text-sm text-zinc-300">{x.outcome}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- JOURNEY -->
    <section id="journey" class="pb-20 scroll-mt-28">
      <div class="text-xs uppercase tracking-[0.2em] text-zinc-500">Career Journey</div>
      <h2 class="mt-4 text-2xl font-semibold tracking-tight">Leadership Progression</h2>

      <div class="mt-8 space-y-6">
        {journey.map((j) => (
          <div class={"p-5 " + softCard}>
            <div class="font-semibold">{j.role}</div>
            <div class="mt-1 text-sm text-zinc-400">{j.focus}</div>
          </div>
        ))}
      </div>
    </section>

    <!-- PRINCIPLES -->
    <section id="principles" class="pb-20 scroll-mt-28">
      <div class="text-xs uppercase tracking-[0.2em] text-zinc-500">Leadership Principles</div>
      <h2 class="mt-4 text-2xl font-semibold tracking-tight">How I Lead</h2>

      <div class="mt-8 max-w-3xl space-y-5">
        {principles.map((p) => (
          <div class={"p-5 " + softCard}>
            <div class="text-sm font-semibold">{p.t}</div>
            <p class="mt-2 text-sm leading-relaxed text-zinc-300">{p.d}</p>
          </div>
        ))}

        <div class={"p-5 " + softCard}>
          <div class="text-sm font-semibold">Operating Cadence</div>
          <p class="mt-2 text-sm leading-relaxed text-zinc-300">
            Weekly Execution Reviews • Monthly Service Health Reviews • Quarterly Business Alignment (QBRs) —
            Ensuring Visibility, Accountability, And Continuous Improvement Across IT And OT.
          </p>
        </div>
      </div>
    </section>

    <div class={divider}></div>

    <!-- CONTACT -->
    <section id="contact" class="pb-24 scroll-mt-28">
      <div class="text-xs uppercase tracking-[0.2em] text-zinc-500">Contact</div>
      <h2 class="mt-4 text-2xl font-semibold tracking-tight">Let’s Connect</h2>

      <p class="mt-4 max-w-xl text-zinc-300 leading-relaxed">
        Open To Senior Technology Leadership Opportunities, Cloud/AI Transformation Programs, IT/OT Modernization, And Strategic Consulting Engagements.
      </p>

      <div class="mt-7 flex flex-wrap gap-3">
        <a href={`mailto:${email}`} class="rounded-xl bg-white px-5 py-3 text-sm font-medium text-zinc-900 hover:bg-zinc-200 transition">
          Email
        </a>

        <a href={linkedin} target="_blank" class="rounded-xl border border-white/20 bg-white/5 px-5 py-3 text-sm text-white hover:bg-white/10 transition">
          LinkedIn
        </a>

        <a href="/resume.pdf" target="_blank" class="rounded-xl border border-white/20 bg-white/5 px-5 py-3 text-sm text-white hover:bg-white/10 transition">
          Resume
        </a>
      </div>

      <div class="mt-6 text-sm text-zinc-400">
        Email:{" "}
        <a class="underline underline-offset-4 hover:text-white" href={`mailto:${email}`}>
          {email}
        </a>
        <span class="mx-2 text-zinc-600">•</span>
        LinkedIn:{" "}
        <a class="underline underline-offset-4 hover:text-white" href={linkedin} target="_blank">
          sahil-arora-38263b158
        </a>
      </div>
    </section>
  </main>

  <footer class="border-t border-white/10">
    <div class="mx-auto max-w-6xl px-6 py-6 text-xs text-zinc-400 md:px-8">
      © {new Date().getFullYear()} {name}
    </div>
  </footer>
</BaseLayout>